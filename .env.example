# ── Lattice environment variables ──────────────────────────────────────────
# Copy to .env.local for local development. On Vercel, set these in
# Project → Settings → Environment Variables. Never commit real values.
#
# IMPORTANT: VITE_* variables are inlined into the client bundle AT BUILD
# TIME. Adding or changing them on Vercel requires a REDEPLOY of the
# Production environment before they take effect.

# Google OAuth 2.0 Web client id (Google Cloud Console → Credentials).
# Required for real sign-in and Google Drive sync. When empty, Lattice
# falls back to a local mock account and Drive sync stays disabled.
# Checklist for production:
#   1. OAuth client type "Web application"
#   2. Your deploy URL (e.g. https://<app>.vercel.app) is listed under
#      "Authorized JavaScript origins"
#   3. "Google Drive API" is enabled in the same Google Cloud project
#   4. Set for the Production environment on Vercel, then redeploy
VITE_GOOGLE_CLIENT_ID=

# Optional Google API key. The Drive REST calls Lattice makes are all
# OAuth-authenticated, so this is only needed if you enable discovery-
# based Google APIs later.
VITE_GOOGLE_API_KEY=

# Name of the root folder Lattice creates in the user's Drive.
VITE_GOOGLE_DRIVE_APP_FOLDER=Lattice

# GitHub OAuth app client id (github.com/settings/developers).
# Enables one-click "Connect GitHub" via the /api/github/oauth function.
# Without it, users can still connect by pasting a personal access token.
VITE_GITHUB_CLIENT_ID=

# GitHub OAuth app client secret — SERVER-SIDE ONLY. Read exclusively by
# the Vercel serverless function api/github/oauth.ts to exchange the
# OAuth code for a token. Do NOT prefix with VITE_ (that would leak it
# into the client bundle). Only needed when VITE_GITHUB_CLIENT_ID is set.
GITHUB_CLIENT_SECRET=

# ── Realtime collaboration (Phase 8) ───────────────────────────────────────
# Backend switch. Set to "liveblocks" to enable true cross-device realtime
# (CRDT documents/code/boards, live cursors, server-enforced permissions).
# When empty, Lattice honestly reports that no realtime backend is
# configured; tabs of the same browser still collaborate via CRDT locally.
VITE_REALTIME_BACKEND=

# Liveblocks secret key — SERVER-SIDE ONLY (no VITE_ prefix; never bundled).
# Read by api/realtime/auth.ts and api/realtime/rooms.ts to verify Google
# identities and mint scoped room tokens. Create it at liveblocks.io.
# Requires VITE_GOOGLE_CLIENT_ID too: realtime identity is Google identity.
LIVEBLOCKS_SECRET_KEY=

# Optional overrides for the serverless endpoints (defaults shown).
# VITE_REALTIME_AUTH_URL=/api/realtime/auth
# VITE_REALTIME_ROOMS_URL=/api/realtime/rooms

# ── Remote conversion worker (Phase 8, optional) ───────────────────────────
# HTTP endpoint of an external conversion service (e.g. headless
# LibreOffice) for legacy DOC/PPT and high-fidelity office conversion.
# Contract: POST {url}/convert (multipart: file, sourceFormat,
# targetFormat, projectId) with a Google Bearer token; response = the
# converted file, with x-conversion-engine / x-conversion-warnings /
# x-conversion-unsupported headers. When empty, the UI honestly reports
# that legacy conversion is unavailable and preserves originals.
VITE_CONVERSION_API_URL=

# Deployment environment label: development | preview | production
VITE_APP_ENV=development

# Version string shown in the account menu.
VITE_APP_VERSION=0.8.0
